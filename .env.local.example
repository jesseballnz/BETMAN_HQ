# ─── Stripe ────────────────────────────────────────────────────────────────────
# Required for live subscriber counts. Use your secret key from:
#   https://dashboard.stripe.com/apikeys
#
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_live_...

# Optional: Explicit Stripe Price IDs for BETMAN plans.
# If set, these take priority over interval/metadata detection.
# Find Price IDs at: https://dashboard.stripe.com/products
STRIPE_WEEKLY_PRICE_ID=price_...
STRIPE_DAY_PASS_PRICE_ID=price_...

# Required for Stripe webhook signature verification.
# Get this from: https://dashboard.stripe.com/webhooks
# The webhook endpoint to register is: https://your-domain.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
